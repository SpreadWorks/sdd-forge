{
  "lang": "ja",
  "type": "node-cli",
  "concurrency": 2,
  "docs": {
    "languages": ["en", "ja"],
    "defaultLanguage": "en",
    "mode": "generate",
    "style": {
      "purpose": "user-guide",
      "tone": "polite",
      "customInstruction": ""
    }
  },
  "scan": {
    "include": ["src/**/*.js", "src/**/*.mjs", "src/**/*.cjs", "package.json"],
    "exclude": ["experimental/**"]
  },
  "flow": {
    "merge": "squash"
  },
  "agent": {
    "default": "claude",
    "workDir": ".tmp",
    "timeout": 600,
    "providers": {
      "claude": {
        "command": "claude",
        "args": ["-p", "{{PROMPT}}"],
        "systemPromptFlag": "--system-prompt",
        "profiles": {
          "default": [],
          "opus": ["--model", "opus"],
          "sonnet": ["--model", "sonnet"]
        }
      },
      "codex": {
        "command": "codex",
        "args": ["exec", "--full-auto", "-C", ".tmp", "{{PROMPT}}"],
        "profiles": {
          "default": []
        }
      }
    },
    "commands": {
      "docs.enrich":       { "agent": "codex" },
      "docs.text":         { "agent": "codex" },
      "docs.forge":        { "agent": "codex" },
      "docs.readme":       { "agent": "codex" },
      "docs.agents":       { "agent": "codex" },
      "spec.gate":         { "agent": "claude", "profile": "sonnet" },
      "experimental.workflow.borad.to-issue": { "agent": "codex" },
      "flow.review.draft": { "agent": "codex" },
      "flow.review.final": { "agent": "claude", "profile": "opus" },
      "docs.translate":    { "agent": "codex" }
    }
  }
}
