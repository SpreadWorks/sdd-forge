{
  "name": "sdd-forge",
  "logs": {
    "enabled": true
  },
  "experimental": {
    "workflow": {
      "enable": true,
      "languages": {
        "source": "ja",
        "publish": "en"
      }
    }
  },
  "lang": "ja",
  "type": [
    "node-cli",
    "greenfield",
    "document"
  ],
  "concurrency": 4,
  "docs": {
    "languages": [
      "ja",
      "en"
    ],
    "defaultLanguage": "en",
    "mode": "generate",
    "exclude": [
      "experimental/**",
      "src/presets/**"
    ],
    "style": {
      "purpose": "user-guide",
      "tone": "polite",
      "customInstruction": ""
    }
  },
  "chapters": [
    {
      "chapter": "overview.md",
      "desc": "sdd-forge の目的・設計思想・主要機能の概要"
    },
    {
      "chapter": "stack_and_ops.md",
      "desc": "Node.js ランタイム、外部依存なしポリシー、動作要件"
    },
    {
      "chapter": "project_structure.md",
      "desc": "src/ のディレクトリ構造、3層ディスパッチ、プリセットシステム"
    },
    {
      "chapter": "cli_commands.md",
      "desc": "docs/spec/flow サブコマンド群、オプション、使用例、終了コード"
    },
    {
      "chapter": "configuration.md",
      "desc": "config.json スキーマ、agent 設定、プリセット設定、flow 設定"
    },
    {
      "chapter": "internal_design.md",
      "desc": "テンプレートエンジン、DataSource、enrich パイプライン、言語ハンドラ"
    },
    {
      "chapter": "development_testing.md",
      "exclude": true
    }
  ],
  "scan": {
    "include": [
      "src/**/*.js",
      "src/**/*.mjs",
      "src/**/*.cjs",
      "package.json"
    ],
    "exclude": [
      "experimental/**"
    ]
  },
  "flow": {
    "merge": "squash"
  },
  "agent": {
    "default": "claude/sonnet",
    "workDir": ".tmp",
    "timeout": 600,
    "providers": {
      "claude/sonnet": {
        "command": "claude",
        "args": ["-p", "{{PROMPT}}", "--model", "sonnet"],
        "systemPromptFlag": "--system-prompt",
        "jsonOutputFlag": "--output-format json"
      },
      "claude/opus": {
        "command": "claude",
        "args": ["-p", "{{PROMPT}}", "--model", "opus"],
        "systemPromptFlag": "--system-prompt",
        "jsonOutputFlag": "--output-format json"
      },
      "codex/gpt-5.4": {
        "command": "codex",
        "args": ["exec", "--full-auto", "-m", "gpt-5.4", "-C", ".tmp", "{{PROMPT}}"],
        "jsonOutputFlag": "--json"
      },
      "codex/gpt-5.3": {
        "command": "codex",
        "args": ["exec", "--full-auto", "-m", "gpt-5.3-codex", "-C", ".tmp", "{{PROMPT}}"],
        "jsonOutputFlag": "--json"
      }
    },
    "profiles": {
      "default": {
        "docs": "codex/gpt-5.3",
        "flow": "codex/gpt-5.3",
        "flow.review.draft": "codex/gpt-5.3"
      }
    }
  }
}
