{
  "lang": "en",
  "type": "php-webapp",
  "docs": {
    "languages": [
      "en"
    ],
    "defaultLanguage": "en"
  },
  "agent": {
    "default": "claude",
    "providers": {
      "claude": {
        "command": "claude",
        "args": [
          "-p",
          "{{PROMPT}}"
        ],
        "systemPromptFlag": "--system-prompt"
      }
    }
  }
}
