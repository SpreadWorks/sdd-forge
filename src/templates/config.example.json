{
  "lang": "ja",
  "output": {
    "languages": ["ja"],
    "default": "ja"
  },
  "type": "webapp/cakephp2",
  "limits": {
    "designTimeoutMs": 900000,
    "concurrency": 5
  },
  "documentStyle": {
    "purpose": "developer-guide",
    "tone": "polite",
    "customInstruction": ""
  },
  "textFill": {
    "projectContext": "",
    "preamblePatterns": [
      { "pattern": "^(Here is|以下に|Based on)", "flags": "i" }
    ]
  },
  "defaultAgent": "claude",
  "providers": {
    "claude": {
      "name": "claude-cli",
      "command": "claude",
      "args": ["--model", "sonnet", "-p", "{{PROMPT}}"],
      "systemPromptFlag": "--system-prompt"
    },
    "codex": {
      "name": "codex-cli",
      "command": "codex",
      "args": ["exec", "--full-auto", "-C", ".tmp", "{{PROMPT}}"]
    }
  }
}
