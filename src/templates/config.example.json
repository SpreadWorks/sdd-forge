{
  "lang": "ja",
  "output": {
    "languages": ["ja"],
    "default": "ja"
  },
  "type": "cakephp2",
  "limits": {
    "agentTimeout": 300,
    "concurrency": 5
  },
  "documentStyle": {
    "purpose": "developer-guide",
    "tone": "polite",
    "customInstruction": ""
  },
  "agentWorkDir": ".tmp",
  "agent": {
    "default": "claude",
    "providers": {
      "claude": {
        "command": "claude",
        "args": ["-p", "{{PROMPT}}"],
        "systemPromptFlag": "--system-prompt",
        "profiles": {
          "default": ["--model", "sonnet"],
          "opus": ["--model", "opus"],
          "sonnet": ["--model", "sonnet"]
        }
      },
      "codex": {
        "command": "codex",
        "args": ["exec", "--full-auto", "-C", ".tmp", "{{PROMPT}}"],
        "profiles": {
          "default": []
        }
      }
    },
    "commands": {
      "docs.enrich":       { "agent": "claude", "profile": "default" },
      "docs.text":         { "agent": "claude", "profile": "default" },
      "docs.forge":        { "agent": "claude", "profile": "default" },
      "docs.readme":       { "agent": "claude", "profile": "default" },
      "docs.agents":       { "agent": "claude", "profile": "default" },
      "docs.translate":    { "agent": "claude", "profile": "default" },
      "spec.gate":         { "agent": "claude", "profile": "default" },
      "flow.review.draft": { "agent": "claude", "profile": "default" },
      "flow.review.final": { "agent": "claude", "profile": "default" }
    }
  }
}
